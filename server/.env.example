# Environment Configuration
# Copy this file to .env and fill in your values

# =============================================
# SERVER
# =============================================
PORT=3001
NODE_ENV=production

# =============================================
# DOMAIN
# =============================================
APP_DOMAIN=https://tuphim.online
# Secret admin path - change this to something unique!
ADMIN_SECRET_PATH=qltv-tp8x2024

# =============================================
# JWT AUTH
# =============================================
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=8h

# =============================================
# ADMIN CREDENTIALS
# =============================================
ADMIN_USERNAME=tuphim_admin
# Run: node -e "const b=require('bcryptjs');console.log(b.hashSync('YOUR_PASSWORD',12))" to generate
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# =============================================
# IPA SIGNING (cert_legacy.p12, password: 1)
# =============================================
CERT_PATH=../certificate/cert_legacy.p12
CERT_PASSWORD=1
PROVISION_PATH=../certificate/cert.mobileprovision

# =============================================
# APP INFO
# =============================================
APP_NAME=TuPhim
BUNDLE_ID=com.tophim.app
APP_VERSION=2.1.0

# =============================================
# STORAGE
# =============================================
STORAGE_PATH=./storage
# Max upload size in MB
MAX_UPLOAD_MB=500
